# Port d'écoute (Render le surcharge automatiquement)
PORT=4000

# Secret pour signer les JWT - REMPLACEZ par une chaîne aléatoire longue
# Génération rapide : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-please-very-long-random-string

# Connexion PostgreSQL (Supabase)
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres.xxx:YOUR_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Origines autorisées (CORS) - séparées par virgules
# En prod, ajoutez votre URL GitHub Pages
CORS_ORIGINS=http://localhost:5173

# Admin par défaut créé au premier démarrage si la table users est vide
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Administrateur

# Webhook Power Automate pour notifier la liste Teams à chaque Proforma créée.
# (Laisser vide si non utilisé — pas d'envoi.)
# Création : Power Automate → "Instant cloud flow" → trigger "When a HTTP request
# is received" → action "Create item" sur ta liste Teams/SharePoint.
TEAMS_WEBHOOK_URL=
